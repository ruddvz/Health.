	"component_specs": {
		"AppShell": {
			"description": "Main mobile shell. Holds status area, page content, and bottom nav.",
			"layout": {
				"width": 393,
				"min_height": 852,
				"background": "bg",
				"padding": 16,
				"bottom_padding": 108
			},
			"css_requirements": [
				"max-width: 430px on desktop",
				"min-height: 100dvh",
				"background uses dot grid at 15% opacity",
				"overflow-x hidden"
			]
		},
		"ScreenHeader": {
			"height": "auto",
			"slots": ["eyebrow", "title", "subtitle", "right_action"],
			"style": {
				"title_token": "screen_title",
				"eyebrow_token": "mono_label",
				"title_color": "text_1",
				"eyebrow_color": "text_3",
				"margin_bottom": 14
			}
		},
		"BottomNav": {
			"position": {
				"x": 0,
				"y": 776,
				"w": 393,
				"h": 76
			},
			"style": {
				"background": "rgba(11,11,11,0.92)",
				"backdrop_filter": "blur(18px)",
				"border_top": "hairline",
				"padding": "8px 12px calc(8px + env(safe-area-inset-bottom))",
				"item_width": "20%",
				"active_color": "red",
				"inactive_color": "text_3"
			},
			"states": {
				"active": {
					"icon_color": "red",
					"label_color": "red"
				},
				"inactive": {
					"icon_color": "text_3",
					"label_color": "text_3"
				},
				"pressed": {
					"scale": 0.96
				}
			}
		},
		"NothingWidget": {
			"description": "Base card for most dashboard modules.",
			"base_style": {
				"background": "linear-gradient(180deg, #181818 0%, #111111 100%)",
				"border": "standard",
				"border_radius": 18,
				"padding": 14,
				"box_shadow": "card",
				"overflow": "hidden"
			},
			"optional_decor": {
				"dot_grid": true,
				"red_accent_line": false,
				"corner_glyph": false
			}
		},
		"RedButton": {
			"height": 52,
			"border_radius": 12,
			"background": "red",
			"color": "#FFFFFF",
			"font": "body_small",
			"font_weight": 650,
			"states": {
				"hover": {
					"background": "red_hover"
				},
				"pressed": {
					"background": "red_pressed",
					"scale": 0.985
				},
				"disabled": {
					"background": "#3A1A1A",
					"color": "text_3"
				}
			}
		},
		"SegmentedControl": {
			"height": 38,
			"background": "surface_1",
			"border": "hairline",
			"border_radius": 12,
			"selected": {
				"background": "red",
				"color": "#FFFFFF"
			},
			"unselected": {
				"background": "transparent",
				"color": "text_2"
			}
		},
		"MetricRing": {
			"size": 78,
			"stroke_width": 6,
			"track": "rgba(255,255,255,0.08)",
			"progress": "red",
			"center_value_token": "metric_medium",
			"center_label_token": "mono_label"
		},
		"GlyphProgress": {
			"segments": 10,
			"filled_symbol": "●",
			"empty_symbol": "○",
			"filled_color": "red",
			"empty_color": "line_3",
			"font": "font_mono"
		},
		"ListRow": {
			"height_min": 54,
			"background": "surface_1",
			"border": "hairline",
			"border_radius": 14,
			"padding": "12px 14px",
			"title_token": "body",
			"subtitle_token": "body_small",
			"right_meta_token": "body_small"
		},
		"WarningCard": {
			"background": "rgba(255,42,42,0.09)",
			"border": "red",
			"border_radius": 16,
			"padding": 14,
			"title_color": "red",
			"body_color": "text_2"
		}
	},
