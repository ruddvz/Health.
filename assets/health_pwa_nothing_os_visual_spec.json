	"data_model_requirements": {
		"plan_storage_key": "health.v2.plan",
		"progress_storage_key": "health.v2.progress",
		"grocery_storage_key": "health.v2.grocery",
		"settings_storage_key": "health.v2.settings",
		"required_plan_sections": [
			"meta",
			"user",
			"phases",
			"meal_plan",
			"prep_guide",
			"grocery",
			"supplements"
		],
		"recommended_plan_sections": [
			"schedule",
			"training",
			"progress",
			"safety",
			"flavour_rotations",
			"weekly_check_in"
		],
		"validation_levels": {
			"error": "Block import/rendering",
			"warning": "Allow import but show diagnostics",
			"info": "Suggestion only"
		},
		"core_warnings": [
			"Meal calories differ from phase target by more than 100 kcal.",
			"Meal times do not match user wake/sleep/training schedule.",
			"Training notes exist but no full training program exists.",
			"Supplement claims are missing safety notes.",
			"Grocery prices are not dated or user-editable."
		]
	},
	"interaction_specs": {
		"upload_plan": {
			"steps": [
				"file_select",
				"size_check",
				"json_parse",
				"schema_validate",
				"normalize",
				"save_local",
				"navigate_today"
			],
			"error_ui": "Inline error card on import screen with exact reason."
		},
		"paste_json": {
			"modal": true,
			"textarea_min_height": 280,
			"actions": ["Validate", "Cancel"]
		},
		"day_type_toggle": {
			"location": ["today", "meals"],
			"state_key": "health.v2.activeDayType",
			"options": ["workout", "rest"]
		},
		"meal_quick_fix": {
			"open_as": "bottom_sheet",
			"suggestions": ["Greek yogurt", "banana", "rice", "whey", "cottage cheese"],
			"logic": "macroRepair.calculateGap(targets, actualTotals)"
		},
		"start_workout": {
			"route": "/train/session",
			"persists": ["sets", "reps", "weight", "duration", "notes"]
		},
		"weekly_checkin": {
			"fields": ["weight_kg", "waist_cm", "energy_1_10", "sleep_hours", "notes"],
			"frequency": "weekly",
			"storage": "health.v2.progress"
		},
		"delete_local_data": {
			"requires_confirm": true,
			"confirm_copy": "Delete all local app data from this device? This cannot be undone unless you exported a backup.",
			"keys_to_clear": [
				"health.v2.plan",
				"health.v2.progress",
				"health.v2.grocery",
				"health.v2.settings"
			]
		}
	},
